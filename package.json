    "pkg-pr-new": "^0.0.75",
    "reflect-metadata": "^0.2.2",
    "sqlite3": "^5.1.7",
    "tsup": "^8.5.1",
    "typeorm": "^0.3.29",
    "typeorm-naming-strategies": "^4.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
