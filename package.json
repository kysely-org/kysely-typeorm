    "publint": "^0.3.21",
    "reflect-metadata": "0.2.2",
    "sqlite3": "5.1.7",
    "tsdown": "0.22.1",
    "typeorm": "0.3.29",
    "typeorm-naming-strategies": "4.1.0",
    "typescript": "5.9.3",
