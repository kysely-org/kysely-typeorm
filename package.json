{
  "name": "kysely-typeorm",
  "version": "0.3.0",
  "type": "module",
  "description": "Kysely dialect for TypeORM",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kysely-org/kysely-typeorm.git"
  },
  "homepage": "https://kysely.dev",
  "author": "Igal Klebanov <igalklebanov@gmail.com>",
  "license": "MIT",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "kysely",
    "typeorm",
    "postgres",
    "mysql",
    "postgresql",
    "mariadb",
    "sqlite",
    "better-sqlite3",
    "mssql",
    "dialect"
  ],
  "scripts": {
    "build": "tsdown",
    "lint": "biome ci",
    "lint:deno": "deno lint --config=\"deno.lint.json\" ./src",
    "prepublishOnly": "pnpm build",
    "script:align-versions": "node --experimental-strip-types scripts/align-versions.mts",
    "start": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "version": "pnpm script:align-versions && git add ."
  },
  "peerDependencies": {
    "kysely": "^0.29",
    "typeorm": "^1"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "0.18.3",
    "@arktype/attest": "0.56.0",
    "@biomejs/biome": "2.4.16",
    "@tsconfig/node22": "22.0.5",
    "@types/lodash": "4.17.24",
    "@types/node": "25.9.1",
    "@types/pg": "8.20.0",
    "better-sqlite3": "12.10.0",
    "jsr": "0.14.3",
    "kysely": "0.29.2",
    "lodash": "4.18.1",
    "mssql": "12.5.5",
    "mysql2": "3.22.5",
    "pathe": "2.0.3",
    "pg": "8.21.0",
    "pg-query-stream": "4.15.0",
    "publint": "0.3.21",
    "reflect-metadata": "0.2.2",
    "sql.js": "1.14.1",
    "tsdown": "0.22.2",
    "typeorm": "1.0.0",
    "typeorm-naming-strategies": "4.1.0",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "sideEffects": false,
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1",
  "engines": {
    "node": ">=22"
  }
}
